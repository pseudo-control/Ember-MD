prefix=/Users/controller/Desktop/Ember-MD/vendor/xtb-env
includedir=${prefix}/include
libdir=${prefix}/lib

Name: tblite
Description: Light-weight tight-binding framework
Version: 0.4.0
Requires.private: mctc-lib >= 0.3.0, dftd4 < 4, dftd4 >= 3.4.0, s-dftd3 >= 0.6.0, toml-f >= 0.4.0
Libs: -L${libdir} -ltblite
Libs.private: -fopenmp -llapack -lblas
Cflags: -I${includedir} -I${includedir}/tblite/gcc-13.3.0
